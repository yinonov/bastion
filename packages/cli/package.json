{
  "name": "@bastion/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "bastion": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -b tsconfig.json",
    "lint": "tsc -b tsconfig.json",
    "test": "tsc -b tsconfig.json && node --test \"dist/**/*.test.js\"",
    "bastion": "tsx src/index.ts"
  },
  "dependencies": {
    "@bastion/core": "workspace:*",
    "@bastion/edge": "workspace:*",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
