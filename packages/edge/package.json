{
  "name": "@bastion/edge",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/dev.ts",
    "typecheck": "tsc -b tsconfig.json",
    "lint": "tsc -b tsconfig.json",
    "test": "tsc -b tsconfig.json && node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "@bastion/core": "workspace:*",
    "@bastion/insights": "workspace:*",
    "@fastify/reply-from": "^12.6.2",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
